# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Azure AD / Microsoft SSO
VITE_AZURE_CLIENT_ID=your-azure-client-id
VITE_AZURE_TENANT_ID=your-azure-tenant-id
VITE_REDIRECT_URI=https://your-domain.com/

# PHI Encryption (HIPAA)
VITE_PHI_ENCRYPTION_KEY=generate-a-strong-random-key

# Super Admin
VITE_SUPER_ADMIN_PASSWORD=change-this-password

# Default bulk user password
VITE_DEFAULT_USER_PASSWORD=change-this-password
